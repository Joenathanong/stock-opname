# Google Sheets Integration
# Paste your Google Sheet ID (dari URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account Key (paste sebagai JSON string satu baris)
# Buat di: https://console.cloud.google.com → IAM & Admin → Service Accounts
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}
